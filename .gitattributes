# Auto detect text files and perform LF normalization
* text=auto

# Source code — enforce LF
*.java text eol=lf
*.py text eol=lf

# Linux/container files
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Windows scripts — keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf